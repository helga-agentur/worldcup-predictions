# Local secrets
.env

# macOS and editor files
.DS_Store
.idea/

# Python bytecode and tool caches
.pycache/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# Generated runtime data, reports, and published site output
/data/
/logs/*
!/logs/.gitkeep
/reports/*
!/reports/.gitkeep
/public/

# Python build artifacts
/dist/
/build/
*.egg-info/

# Allow AGENTS.md to be committed.
!AGENTS.md
